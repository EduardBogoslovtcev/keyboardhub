<h1>My Account</h1>

<p>Email: <%= @user.email %></p>

<p>
  Address:
  <%= @user.address %>,
  <%= @user.city %>,
  <%= @user.postal_code %>,
  <%= @user.province&.name %>
</p>

<br>

<%= link_to "Edit Address Info", edit_account_path, class: "btn" %>

<%= link_to "My Orders", orders_path, class: "btn" %>

<br><br>

<%= button_to "Log Out",
  destroy_user_session_path,
  method: :delete,
  class: "btn" %>