<h1>New Product</h1>

<%= form_with model: [:admin, @product] do |f| %>

  <%= f.text_field :name, placeholder: "Name" %><br>
  <%= f.text_area :description %><br>
  <%= f.number_field :price %><br>
  <%= f.text_field :image, placeholder: "Image URL" %><br>

  <%= f.submit "Create", class: "btn" %>

<% end %>