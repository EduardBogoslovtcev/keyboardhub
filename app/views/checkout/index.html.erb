<h1>Checkout</h1>

<% subtotal = 0 %>

<% @products.each do |p| %>
  <% quantity = session[:cart][p.id.to_s] %>
  <% subtotal += p.price * quantity %>
<% end %>

<% tax_rate = current_user&.province&.tax_rate || 0 %>
<% tax = subtotal * tax_rate %>
<% total = subtotal + tax %>

<hr>

<p>Subtotal: $<%= subtotal.round(2) %></p>
<p>Tax (<%= (tax_rate * 100).round(2) %>%): $<%= tax.round(2) %></p>

<h2>Total: $<%= total.round(2) %></h2>

<%= button_to "Place Order",
  checkout_create_path,
  method: :post,
  class: "btn" %>