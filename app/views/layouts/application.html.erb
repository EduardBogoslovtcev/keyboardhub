<!DOCTYPE html>
<html>
<head>
  <title>KeyboardHub</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <style>
    body { font-family: Arial; margin: 0; background: #fff; color: #111; }
    nav { border-bottom: 1px solid #e5e7eb; padding: 15px; display: flex; justify-content: space-between; }
    a { text-decoration: none; color: black; margin-right: 15px; }
    .container { padding: 30px; }
    .btn { background: #2563eb; color: white; padding: 10px 15px; border-radius: 6px; }
    .card { border: 1px solid #e5e7eb; padding: 15px; border-radius: 10px; }
  </style>
</head>

<body>
  <nav>
    <strong>KeyboardHub</strong>

    <div>
      <%= link_to "Products", root_path %>
      <%= link_to "Cart", cart_path %>

      <% if user_signed_in? %>
        <%= link_to "Account", account_path %>
      <% else %>
        <%= link_to "Login", new_user_session_path %>
      <% end %>
    </div>
  </nav>

  <div class="container">
    <%= yield %>
  </div>
</body>
</html>