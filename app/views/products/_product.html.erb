<div class="card" style="padding:15px;">

  <img src="<%= product.image %>" style="width:100%; height:200px; object-fit:cover;">

  <h3><%= product.name %></h3>

  <p style="color:gray;"><%= product.brand&.name %></p>

  <p>$<%= product.price %></p>

  <%= link_to "View", product_path(product), class: "btn" %>

</div>